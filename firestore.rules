rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo usuarios autenticados pueden acceder a sus propios datos
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
    match /analyses/{uid}/{document=**} {
      allow read, write: if request.auth.uid == uid;
    }
  }
}

