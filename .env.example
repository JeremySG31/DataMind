# OpenRouter API Key
# Obtén tu API key GRATUITA en: https://openrouter.io/keys
# Soporta acceso a múltiples modelos de IA (Claude, Llama, Mistral, etc.)
OPENROUTER_API_KEY=tu_api_key_aqui

# Firebase Configuration
# Obtén estos valores en: https://console.firebase.google.com
# 1. Crea un nuevo proyecto Firebase
# 2. Habilita Authentication (Email/Password)
# 3. Crea una base de datos Firestore
# 4. Copia los valores de tu app web
NEXT_PUBLIC_FIREBASE_API_KEY=tu_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu_proyecto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=tu_app_id
